    {
      "name": "Auth",
      "description": "Получение токенов для студента и преподавателя с автоматическим сохранением в collection variables.",
      "item": [
        {
          "name": "Student Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Student token returned 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Student token exists', function () {",
                  "    pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('student_token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{student_username}}\",\n  \"password\": \"{{student_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/token/",
            "description": "Получает токен студента и сохраняет его в collection variable `student_token`."
          },
          "response": []
        },
        {
          "name": "Teacher Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Teacher token returned 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Teacher token exists', function () {",
                  "    pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('teacher_token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{teacher_username}}\",\n  \"password\": \"{{teacher_password}}\"\n}",
