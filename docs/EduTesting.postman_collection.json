{
  "info": {
    "_postman_id": "84fb9f7b-7f49-4c0d-91d8-4ad3f4d56401",
    "name": "EduTesting API Demo",
    "description": "Коллекция для демонстрации ключевых API-сценариев EduTesting: авторизация, прохождение теста, достижения, аналитика, контроль подозрительных попыток, индивидуальные условия и апелляции.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Получение токенов для студента и преподавателя.",
      "item": [
        {
          "name": "Student Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('student_token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{student_username}}\",\n  \"password\": \"{{student_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/token/",
            "description": "Получает токен студента и сохраняет его в collection variable `student_token`."
          },
          "response": []
        },
        {
          "name": "Teacher Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('teacher_token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{teacher_username}}\",\n  \"password\": \"{{teacher_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/token/",
            "description": "Получает токен преподавателя и сохраняет его в collection variable `teacher_token`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Student Flow",
      "description": "Полный сценарий студента: вход, запись на курс, прохождение теста, результат, достижения и апелляция.",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              }
            ],
            "url": "{{base_url}}/api/me/",
            "description": "Проверка корректности токена студента."
          },
          "response": []
        },
        {
          "name": "Enroll To Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              }
            ],
            "url": "{{base_url}}/api/courses/{{course_id}}/enroll/",
            "description": "Записывает студента на курс."
          },
          "response": []
        },
        {
          "name": "Start Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.attempt && data.attempt.id) {",
                  "    pm.environment.set('attempt_id', data.attempt.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              }
            ],
            "url": "{{base_url}}/api/quizzes/{{quiz_id}}/start/",
            "description": "Создает или переиспользует активную попытку и сохраняет `attempt_id` в environment."
          },
          "response": []
        },
        {
          "name": "Save Draft",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{draft_body}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/attempts/{{attempt_id}}/draft/",
            "description": "Автосохраняет промежуточные ответы."
          },
          "response": []
        },
        {
          "name": "Submit Attempt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{submit_body}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/attempts/{{attempt_id}}/submit/",
            "description": "Отправляет попытку на проверку и возвращает подробный результат."
          },
          "response": []
        },
        {
          "name": "Attempt Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              }
            ],
            "url": "{{base_url}}/api/attempts/{{attempt_id}}/",
            "description": "Возвращает полный отчет по попытке, включая сравнение с предыдущей и новые достижения."
          },
          "response": []
        },
        {
          "name": "My Achievements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              }
            ],
            "url": "{{base_url}}/api/my/achievements/",
            "description": "Возвращает вычисляемые достижения текущего студента."
          },
          "response": []
        },
        {
          "name": "Submit Appeal",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "    pm.environment.set('appeal_id', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_prefix}} {{student_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{appeal_body}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/attempts/{{attempt_id}}/appeal/",
            "description": "Подает апелляцию по завершенной попытке и сохраняет `appeal_id` в environment."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Teacher Flow",
      "description": "Ключевые запросы преподавателя: аналитика, контроль честности, индивидуальные условия и апелляции.",
      "item": [
