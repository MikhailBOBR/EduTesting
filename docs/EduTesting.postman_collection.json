              "raw": "{{appeal_review_body}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/appeals/{{appeal_id}}/review/",
            "description": "Рассматривает апелляцию и возвращает решение преподавателя."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
